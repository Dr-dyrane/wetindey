# WetinDey — environment
#
# Copy to `.env.local` and fill in. Never commit real values.
#
# This file lists the variables the code ACTUALLY READS, and nothing else.
# It previously declared 14 keys, 9 of which no code read, and it named the map
# token `NEXT_PUBLIC_MAP_TOKEN` while the code reads
# `NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN`. Anyone bootstrapping from the example got a
# blank map and no error, because the adapter falls back to "" rather than
# throwing (src/integrations/maps/MapboxAdapter.ts). Names here are exact.
# If you add a key, add its reader in the same commit or leave it out.
#
# Readers below are cited by FILE and SYMBOL, never by line number. Line numbers
# rot silently: these citations said :135 and :201 while the real reads had moved
# to :299 and :258, which is the same class of lie as a doc describing code that
# does not exist. A grep for the variable name always finds the truth.


# ─── Required ────────────────────────────────────────────────────────────────

# Neon Postgres connection string. Must point at a database where you are
# allowed to `CREATE EXTENSION postgis` — `npm run db:seed` does exactly that
# before it migrates. See "The PostGIS gotcha" in README.md.
#   Read by: src/db/index.ts, src/db/seed.ts, drizzle.config.ts
DATABASE_URL=

# Mapbox GL public access token (`pk.…`). Without it the map renders blank and
# silently — there is no error, so a missing token looks like a broken app.
#   Read by: src/integrations/maps/MapboxAdapter.ts   (MapboxAdapter constructor)
#            src/design-system/components/MapboxCanvas.tsx
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=


# ─── Optional ────────────────────────────────────────────────────────────────
# The app runs correctly with everything below unset; error reporting stays off.

# Sentry DSN. The server prefers the private var and falls back to the public
# one; the browser can only ever see the NEXT_PUBLIC one. Both are named
# statically on purpose — Next inlines `process.env.X` only for literal member
# access, so a computed lookup would read as "Sentry is off" forever.
#   Read by: src/lib/report-error.ts:120-121
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Environment label attached to error reports. Server-side only — deliberately
# not read in the browser, where it resolves to undefined. Falls back to NODE_ENV.
#   Read by: src/lib/report-error.ts:187
APP_ENV=development

# Absolute public origin of the deployed site, e.g. https://wetindey.live. It
# drives the canonical tag, the sitemap, robots, and every OpenGraph / JSON-LD
# URL, so they resolve to one host and cannot drift. Falls back to Vercel's
# production URL. Without it AND without VERCEL_PROJECT_PRODUCTION_URL, the
# sitemap and metadataBase refuse to guess an origin and throw, by design.
#   Read by: src/app/sitemap.ts (siteOrigin), src/app/robots.ts,
#            src/lib/seo.tsx, src/app/layout.tsx (metadataBase)
NEXT_PUBLIC_APP_URL=

# Google Search Console verification token (the content="" value of the HTML-tag
# method). Public by design; emitted as <meta name="google-site-verification">.
# Leave blank if you verify by DNS instead. See docs/SEO.md.
#   Read by: src/app/layout.tsx (metadata.verification.google)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Required only when the private CSP report collector is deployed. The
# collector passes the private token explicitly to @vercel/blob; the hourly
# retention route accepts only Vercel Cron's Bearer CRON_SECRET.
#   Read by: src/lib/security/csp-report-store.ts
BLOB_READ_WRITE_TOKEN_PRIVATE=
CRON_SECRET=

# Required only for the guarded Presence retention scheduler. This must be an
# unpooled URL for a dedicated login permitted to SET LOCAL ROLE to
# wetindey_presence_safety. It must never be an owner or general app connection.
#   Read by: src/lib/presence-retention-cleanup.ts
PRESENCE_SAFETY_DATABASE_URL_UNPOOLED=


# ─── Deliberately absent ─────────────────────────────────────────────────────
# Declared in this file before, read by NO code as of this commit. Left out
# rather than carried as cargo. Re-add one only alongside its reader:
#
#   DATABASE_URL_UNPOOLED        BLOB_READ_WRITE_TOKEN
#   NEXT_PUBLIC_MAP_PROVIDER     NEXT_PUBLIC_MAP_TOKEN   (wrong name; see above)
#   GEOCODING_API_TOKEN
#   AUTH_SECRET                  AUTH_TRUST_HOST
#   OPS_ALLOWED_EMAIL_DOMAINS
#
# Note: `vercel env pull` injects its own vars (VERCEL_*, POSTGRES_*, PG*,
# BLOB_*) into .env.local. The app reads none of the generic injected Blob
# variables; the collector reads only the explicitly named private token above.
